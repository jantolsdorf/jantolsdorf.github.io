	title        = {Classification of {Android} {App} {Permissions}: {Tell} {Me} {What} {App} {You} {Are} and {I} {Tell} {You} {What} {You} {Are} {Allowed} to {Do}},
	author       = {Gruschka, Nils and Lo Iacono, Luigi and Tolsdorf, Jan},
