	author       = {Nguyen, Hoai Viet and Tolsdorf, Jan and Lo Iacono, Luigi},
	year         = {2017},
	booktitle    = {Proceedings of the 14th {International} {Conference} on {Trust}, {Privacy} and {Security} in {Digital} {Business} ({TrustBus})},
